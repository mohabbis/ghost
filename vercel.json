{
  "buildCommand": "echo 'Static site - no build required'",
  "outputDirectory": "src",
  "devCommand": "npx serve src",
  "installCommand": "echo 'No dependencies required'",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
